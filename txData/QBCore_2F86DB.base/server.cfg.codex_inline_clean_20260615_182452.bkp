load_server_icon myLogo.png
sv_enforceGameBuild 3095 #DLC The Chop Shop
set resources_useSystemChat true
set mysql_connection_string "mysql://root:Tseegii1015@@localhost/QBCore_2F86DB?charset=utf8mb4"

setr voice_useNativeAudio true
setr voice_defaultCycle "GRAVE"
setr voice_defaultVolume 0.3
setr voice_enableRadioAnim 1
setr voice_syncData 1
setr voice_useSendingRangeOnly false

setr qb_locale "en"

setr UseTarget false

setr inventory:framework "qb"
setr inventory:slots 50
setr inventory:weight 30000
setr inventory:keys '["TAB", "K", "Z"]'
